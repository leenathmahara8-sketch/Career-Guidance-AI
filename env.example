# =============================================================================
# AI/ML Career Guidance System — Environment Configuration Example
# =============================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control — it is listed in .gitignore.
# =============================================================================

# LLM Provider to use for the chatbot service.
# Accepted values: "openai", "gemini", or "ollama"
# Defaults to "openai" if not set.
LLM_PROVIDER=gemini

# API key for OpenAI (required when LLM_PROVIDER=openai).
# Obtain yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# API key for Google Gemini (required when LLM_PROVIDER=gemini).
# Obtain yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama settings (only needed if LLM_PROVIDER=ollama, no key required)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Secret key used by Flask to sign session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change_this_to_a_random_string

# Host address the Flask development server will bind to.
FLASK_HOST=127.0.0.1

# Port the Flask development server will listen on.
FLASK_PORT=5000

# Enable Flask debug mode (auto-reloader + detailed error pages).
FLASK_DEBUG=true
